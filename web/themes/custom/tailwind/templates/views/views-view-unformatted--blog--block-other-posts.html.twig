{#
/**
 * @file
 * Theme override for the "Other posts" block display - unformatted rows.
 * Displays blog post teasers in a 2-column grid (same card form as listing).
 * Uses tailwind:content for layout; the embed must not use Twig’s `only` keyword
 * so `rows` and related view variables remain in scope inside {% block children %}.
 *
 * Available variables:
 * - title: The title of this group of rows. May be empty.
 * - rows: A list of the view's row items.
 *   - attributes: The row's HTML attributes.
 *   - content: The row's content.
 * - view: The view object.
 * - default_row_class: A flag indicating whether default classes should be
 *   used on rows.
 *
 * @see template_preprocess_views_view_unformatted()
 */
#}
{% if rows %}
  {% embed 'tailwind:content' with {
    tag: 'section',
    container: 'narrow',
    padding: 'compact',
    background: 'light',
  } %}
    {% block children %}
      <div class="flex justify-between items-center mb-8">
        <h2 class="text-3xl font-bold text-white mb-0">{{ title|default('See my other posts') }}</h2>
        <a href="/blog" class="text-primary-200 hover:text-white/80 text-sm font-medium focus:outline-none focus:underline">{{ 'All posts'|t }}</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {% for row in rows %}
        {%
          set row_classes = [
            default_row_class ? 'views-row',
          ]
        %}
        <div{{ row.attributes.addClass(row_classes) }}>
          {{ row.content }}
        </div>
      {% endfor %}
      </div>
    {% endblock %}
  {% endembed %}
{% endif %}
