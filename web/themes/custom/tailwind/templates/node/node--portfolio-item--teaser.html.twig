{#
/**
 * @file
 * Theme override to display a portfolio item node in teaser view mode.
 *
 * Available variables:
 * - node: The node entity with limited access to object properties and methods.
 * - label: The title of the node.
 * - content: All node items.
 * - url: Direct URL of the current node.
 *
 * @see template_preprocess_node()
 */
#}
{% set teaser_text = node.field_body.summary|trim ?: node.field_body.value %}
{{ include('tailwind:portfolio-card', {
  url: url,
  image: node.field_image.entity ? (content.field_image|render|striptags('<img>')) : null,
  card_title: label|render|striptags,
  technologies: node.field_technologies.value,
  card_description: teaser_text|striptags,
}) }}
