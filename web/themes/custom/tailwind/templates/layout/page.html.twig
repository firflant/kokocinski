{#
/**
 * @file
 * Theme override to display a single page using Single Directory Components.
 *
 * The doctype, html, head and body tags are not in this template. Instead they
 * can be found in templates/layout/html.html.twig.
 *
 * Available variables:
 *
 * General utility variables:
 * - base_path: The base URL path of the Drupal installation.
 * - is_front: A flag indicating if the current page is the front page.
 * - logged_in: A flag indicating if the user is registered and signed in.
 * - is_admin: A flag indicating if the user has permission to access administration pages.
 *
 * Site identity:
 * - front_page: The URL of the front page.
 * - logo: The path to the logo image, as defined in theme settings.
 * - site_name: The name of the site.
 * - site_slogan: The slogan of the site.
 *
 * Page content (in order of occurrence in the default page.html.twig):
 * - node: Fully loaded node, if there is an automatically-loaded node.
 * - no_page_layout: When TRUE, only navbar + a bare &lt;main&gt; and region
 *   content. Used for Canvas pages, or a blog post node in page context. When
 *   FALSE, the theme adds `page-title` and the `content` SDC.
 * - page_is_canvas: TRUE when the active Canvas full template is used, or
 *   Canvas pages under /canvas/.
 *
 * Regions:
 * - page.primary_menu: Header navigation; place the “Main navigation” (system
 *   menu) block or other menu blocks here.
 * - page.content: The main content of the current page.
 *
 * @see template_preprocess_page()
 * @see html.html.twig
 */
#}

{{ include('tailwind:navbar') }}

{% set container_class = node ? 'max-w-4xl' : 'max-w-7xl' %}

{% if no_page_layout %}

  <main id="main-content" role="main" class="min-h-screen">
    {% if messages %}
      <div class="{{ container_class }} mx-auto mb-4">{{ messages }}</div>
    {% endif %}
    {{ page.content }}
  </main>

{% else %}

    {{ include('tailwind:page-title', {
      title: page_title_string|default(''),
      container: 'narrow',
    }, with_context: false) }}

    {% embed 'tailwind:content' with {
        container: 'narrow',
        padding: 'compact',
        id: 'main-content',
      } %}
        {% block children %}
          {% if messages %}
            <div class="{{ container_class }} mx-auto mb-4">{{ messages }}</div>
          {% endif %}

          {% if page.help %}
            <div class="mb-8">
              {{ page.help }}
            </div>
          {% endif %}

          {{ page.content }}
      {% endblock %}
    {% endembed %}

{% endif %}

{% include '@tailwind/layout/footer.html.twig' %}
