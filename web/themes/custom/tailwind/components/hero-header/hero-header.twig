{# Background Blobs - Decorative background element #}
<div class="fixed inset-0 z-0 overflow-hidden pointer-events-none">
  <div class="absolute top-0 left-1/4 w-96 h-96 bg-accent-main/20 rounded-full mix-blend-screen filter blur-3xl opacity-30 animate-blob"></div>
  <div class="absolute top-0 right-1/4 w-96 h-96 bg-accent-teal/20 rounded-full mix-blend-screen filter blur-3xl opacity-30 animate-blob animation-delay-2000"></div>
</div>

<header class="relative z-10 flex flex-col justify-center items-center md:min-h-[calc(100vh-4rem)] text-center px-6 pt-4 md:pt-0 pb-24 md:pb-0">
  <div class="relative w-48 h-48 mb-8">
    <div class="absolute inset-0 bg-gradient-to-tr from-accent-main to-accent-teal rounded-full blur opacity-75"></div>
    <img src="/{{ directory|default('themes/custom/tailwind') }}/images/profile-pic.jpeg" alt="Profile" class="relative w-full h-full object-cover rounded-full border-2 border-white/10 shadow-2xl">
  </div>

  <h1 class="text-4xl md:text-6xl font-bold text-white mb-6 tracking-tight">
    Frontend & <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent-light to-accent-teal">Drupal Engineer</span>
  </h1>
  <p class="max-w-2xl text-lg md:text-xl text-slate-400 mb-10">
    I partner with digital agencies, CTOs, and business owners to deliver quality frontend, websites, and Content Management Systems.
  </p>

  {% set social_tooltip = 'pointer-events-none absolute top-full left-1/2 z-20 mt-2 -translate-x-1/2 whitespace-nowrap rounded-md bg-slate-900/95 px-2.5 py-1 text-xs font-medium text-slate-100 opacity-0 shadow-lg ring-1 ring-white/10 transition-opacity duration-200 group-hover:opacity-100 group-focus-visible:opacity-100' %}
  <div class="flex space-x-6">
    <a href="https://www.drupal.org/u/firflant" target="_blank" rel="noopener noreferrer" aria-label="Drupal.org profile" class="group relative flex items-center justify-center w-12 h-12 rounded-full bg-white/5 border border-white/10 hover:bg-white/10 hover:scale-110 transition-all duration-300">
      <span class="{{ social_tooltip }}" aria-hidden="true">Drupal.org</span>
      <i class="fab fa-drupal text-xl text-white group-hover:text-accent-light"></i>
    </a>
    <a href="https://github.com/firflant" target="_blank" rel="noopener noreferrer" aria-label="GitHub profile" class="group relative flex items-center justify-center w-12 h-12 rounded-full bg-white/5 border border-white/10 hover:bg-white/10 hover:scale-110 transition-all duration-300">
      <span class="{{ social_tooltip }}" aria-hidden="true">GitHub</span>
      <i class="fab fa-github text-xl text-white group-hover:text-accent-light"></i>
    </a>
    <a href="https://www.linkedin.com/in/michalkokocinski" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn profile" class="group relative flex items-center justify-center w-12 h-12 rounded-full bg-white/5 border border-white/10 hover:bg-white/10 hover:scale-110 transition-all duration-300">
      <span class="{{ social_tooltip }}" aria-hidden="true">LinkedIn</span>
      <i class="fab fa-linkedin-in text-xl text-white group-hover:text-accent-teal"></i>
    </a>
    <a href="#contact" aria-label="Contact" class="group relative flex items-center justify-center w-12 h-12 rounded-full bg-white/5 border border-white/10 hover:bg-white/10 hover:scale-110 transition-all duration-300">
      <span class="{{ social_tooltip }}" aria-hidden="true">Contact</span>
      <i class="fas fa-envelope text-xl text-white group-hover:text-accent-teal"></i>
    </a>
  </div>

  <div class="absolute hidden md:block bottom-10 animate-bounce text-slate-600">
    <i class="fas fa-chevron-down"></i>
  </div>
</header>
