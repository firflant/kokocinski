{% set curated = [
  {
    industry: 'HR & recruitment technology',
    client: 'TechTree',
    focus: 'Senior Frontend Lead for a disruptor startup. Implemented core business flows using an AI-driven development approach.',
    delivery: 'Core team',
  },
  {
    industry: 'Public sector',
    client: 'WAAT Ltd.',
    focus: 'Digital agency execution arm for European Commission initiatives. Delivered multiple high-profile Drupal platforms.',
    delivery: 'Agency partner',
  },
  {
    industry: 'Banking & Real Estate',
    client: 'STX Next',
    focus: 'React development for enterprise clients from various industries.',
    delivery: 'Software house',
  },
  {
    industry: 'Startups (Berlin)',
    client: 'MVP Space',
    focus: 'Bootstrapped and grew frontend architectures for startups across e-mobility, music, university and even funeral sectors.',
    delivery: 'Agency partner',
  },
  {
    industry: 'Enterprise Drupal',
    client: 'Droptica',
    focus: 'Early employee at Poland\'s premier Acquia-certified Drupal agency. Implemented new features and provided ongoing maintenance for client platforms.',
    delivery: 'Agency team',
  },
] %}

<section class="where-contributed" aria-labelledby="where-contributed-heading">
  <div class="mb-12 max-w-3xl">
    <h2 id="where-contributed-heading" class="text-3xl font-bold text-white mb-4">
      Who I've partnered with
    </h2>
    <div class="h-1 w-20 rounded-full mb-8 bg-accent-main" aria-hidden="true"></div>
    <p class="text-lg text-slate-400 leading-relaxed">
      Projects delivered through agencies and directly for startups and public sector clients:
    </p>
  </div>

  <ul class="grid grid-cols-1 gap-5 sm:grid-cols-2 xl:grid-cols-3 list-none m-0 p-0">
    {% for row in curated %}
      <li>
        <article class="flex h-full flex-col rounded-2xl border border-white/5 bg-white/[0.04] px-6 py-7 transition-colors hover:border-white/10 hover:bg-white/[0.06]">
          <div class="mb-5 flex flex-wrap items-baseline justify-between gap-2 gap-y-1">
            <span class="text-[0.7rem] font-semibold uppercase tracking-[0.12em] text-slate-500">
              {{- row.industry -}}
            </span>
            <span class="text-[0.65rem] font-medium uppercase tracking-wide text-accent-teal/90">
              {{- row.delivery ?? 'Via agency' -}}
            </span>
          </div>
          <h3 class="mb-3 text-lg font-semibold tracking-tight text-white">
            {{- row.client -}}
          </h3>
          <p class="mb-0 flex-1 text-sm leading-relaxed text-slate-400">
            {{- row.focus -}}
          </p>
        </article>
      </li>
    {% endfor %}
  </ul>
</section>
