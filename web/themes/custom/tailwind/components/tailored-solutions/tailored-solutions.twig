{% set items = [
  {
    icon: 'fa-rocket',
    title: 'Content Startups',
    description: 'Rapid deployment of scalable content architectures.',
  },
  {
    icon: 'fa-newspaper',
    title: 'Publishing Platforms',
    description: 'High-traffic capability with complex editorial workflows.',
  },
  {
    icon: 'fa-building',
    title: 'Brands & Enterprises',
    description: 'Editable, secure websites that empower marketing teams.',
  },
  {
    icon: 'fa-users-cog',
    title: 'Dev Teams',
    description: 'Augmentation for teams lacking Senior Frontend expertise.',
  },
] %}

{% set home_url = path('<front>') %}
{% set card_class = [
  'group flex h-full flex-col items-center text-center',
  'p-6 rounded-xl bg-white/5 backdrop-blur-sm no-underline ring-1 ring-transparent transition-colors',
  'hover:bg-white/[0.08] hover:ring-accent-main/40 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent-main/60',
]|join(' ') %}

<h2 class="text-center text-2xl font-semibold text-white mb-12">Tailored Solutions For</h2>

<ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 list-none m-0 p-0">
  {% for row in items %}
    <li class="relative">
      <a href="{{ home_url }}" class="{{ card_class }}">
        <i class="fas {{ row.icon }} text-accent-main text-3xl mb-4 shrink-0 group-hover:text-accent-light transition-colors" aria-hidden="true"></i>
        <h4 class="text-white font-medium mb-2">{{ row.title }}</h4>
        <p class="text-sm text-slate-500">{{ row.description }}</p>
      </a>
    </li>
  {% endfor %}
</ul>
